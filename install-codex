#!/usr/bin/env bash
# superstack install-codex — install the full pipeline for OpenAI Codex
set -e

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
CODEX_SKILLS_DIR="$HOME/.codex/skills"
GSTACK_CODEX_STAMP="$CODEX_SKILLS_DIR/.superstack-gstack-codex-rev"

CODEX_OVERLAY_SKILLS="claude pipeline pipeline-update pipeline-update_codex writing-plans subagent-driven-development test-driven-development verification-before-completion"
FORCE_GSTACK_CODEX="${SUPERSTACK_FORCE_GSTACK_CODEX:-0}"
COMPACT_CODEX_DESCRIPTIONS="${SUPERSTACK_COMPACT_CODEX_DESCRIPTIONS:-1}"

while [ $# -gt 0 ]; do
    case "$1" in
        --force-gstack-codex)
            FORCE_GSTACK_CODEX=1
            shift
            ;;
        --no-compact-descriptions)
            COMPACT_CODEX_DESCRIPTIONS=0
            shift
            ;;
        *)
            echo "Unknown option: $1" >&2
            echo "Usage: ./install-codex [--force-gstack-codex] [--no-compact-descriptions]" >&2
            exit 1
            ;;
    esac
done

compact_codex_skill_descriptions() {
    [ "$COMPACT_CODEX_DESCRIPTIONS" = "1" ] || return 0
    command -v perl >/dev/null 2>&1 || {
        echo "  WARNING: perl not found; skipping Codex skill description compaction."
        return 0
    }

    changed=false
    for skill_md in "$CODEX_SKILLS_DIR"/gstack/SKILL.md "$CODEX_SKILLS_DIR"/gstack-*/SKILL.md; do
        [ -f "$skill_md" ] || continue
        grep -q '^description: |' "$skill_md" || continue
        perl -0pi -e '
            s{\A---\n(.*?)\n---\n}{
                my $frontmatter = $1;
                $frontmatter =~ s{\ndescription:\s*\|\n((?:[ \t]+[^\n]*\n?)+)}{
                    my $desc = $1;
                    $desc =~ s/^[ \t]+//mg;
                    $desc =~ s/\s+/ /g;
                    $desc =~ s/^\s+|\s+$//g;
                    $desc =~ s/\s*\(gstack\)\s*$//;
                    my $compact = $desc =~ /^(.+?[.!?])(?:\s|$)/ ? $1 : $desc;
                    if (length($compact) > 140) {
                        $compact = substr($compact, 0, 140);
                        $compact =~ s/\s+\S*$//;
                    }
                    $compact =~ s/[\\"]/\\$&/g;
                    $compact .= "." unless $compact =~ /[.!?]$/;
                    "\ndescription: \"$compact (gstack)\"\n";
                }e;
                $frontmatter =~ s/\n+\z//;
                "---\n$frontmatter\n---\n";
            }se
        ' "$skill_md"
        changed=true
    done

    if $changed; then
        echo "  Compacted generated gstack skill descriptions for Codex."
    else
        echo "  Generated gstack skill descriptions already compact."
    fi
}

gstack_codex_is_current() {
    [ "$FORCE_GSTACK_CODEX" = "1" ] && return 1
    [ -f "$GSTACK_CODEX_STAMP" ] || return 1
    [ -e "$CODEX_SKILLS_DIR/gstack/SKILL.md" ] || return 1
    [ -e "$CODEX_SKILLS_DIR/gstack-qa/SKILL.md" ] || return 1
    [ -e "$CODEX_SKILLS_DIR/gstack-claude/SKILL.md" ] || return 1
    grep -q -- '--effort xhigh' "$CODEX_SKILLS_DIR/gstack-claude/SKILL.md" 2>/dev/null || return 1

    current_rev=$(git -C "$CLAUDE_SKILLS_DIR/gstack" rev-parse HEAD 2>/dev/null || true)
    [ -n "$current_rev" ] || return 1
    [ "$(cat "$GSTACK_CODEX_STAMP" 2>/dev/null)" = "$current_rev" ]
}

echo "=== superstack install-codex ==="

echo ""
echo "[1/3] Ensuring upstream sources are installed..."
"$REPO_DIR/setup"

echo ""
echo "[1b/3] Refreshing Codex superpowers overlays..."
"$REPO_DIR/scripts/refresh-codex-superpowers"

echo ""
echo "[2/3] Generating gstack Codex skills..."
if [ ! -x "$CLAUDE_SKILLS_DIR/gstack/setup" ]; then
    echo "  ERROR: gstack setup not found at $CLAUDE_SKILLS_DIR/gstack/setup"
    echo "  Run ./setup first, then retry ./install-codex."
    exit 1
fi

if gstack_codex_is_current; then
    echo "  gstack Codex skills already current, skipped."
else
    cd "$CLAUDE_SKILLS_DIR/gstack"
    ./setup --host codex
    mkdir -p "$CODEX_SKILLS_DIR"
    git -C "$CLAUDE_SKILLS_DIR/gstack" rev-parse HEAD > "$GSTACK_CODEX_STAMP" 2>/dev/null || true
fi

compact_codex_skill_descriptions

echo ""
echo "[3/3] Installing Codex pipeline overlays..."
mkdir -p "$CODEX_SKILLS_DIR"

for skill in $CODEX_OVERLAY_SKILLS; do
    src="$REPO_DIR/codex-skills/$skill"
    dst="$CODEX_SKILLS_DIR/$skill"

    if [ ! -f "$src/SKILL.md" ]; then
        echo "  ERROR: missing Codex overlay skill: $src/SKILL.md"
        exit 1
    fi

    # Replace the overlay directory rather than merging into it, so removed
    # upstream files do not linger in ~/.codex/skills across updates.
    rm -rf "$dst"
    mkdir -p "$dst"
    cp -R "$src/." "$dst/"
    echo "  Installed $skill"
done

echo ""
echo "=== Codex pipeline installed. ==="
echo "  gstack Codex skills: $CODEX_SKILLS_DIR/gstack-*"
echo "  superstack overlays: $REPO_DIR/codex-skills"
echo "  Codex skills dir:    $CODEX_SKILLS_DIR"
echo ""
echo "Rerun ./install-codex after ./update to refresh the Codex install."
