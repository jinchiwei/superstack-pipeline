#!/usr/bin/env bash
# superstack update — pull latest from gstack + superpowers
set -e

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$HOME/.claude/skills"
UPSTREAM_DIR="$REPO_DIR/.upstream"

SUPERPOWERS_SKILLS="subagent-driven-development test-driven-development verification-before-completion writing-plans"
CUSTOM_SKILLS="pipeline pipeline-update"

echo "=== superstack update ==="

# --- 1. gstack ---
echo ""
echo "[1/3] Updating gstack..."
if [ -d "$SKILLS_DIR/gstack/.git" ]; then
    cd "$SKILLS_DIR/gstack"
    BEFORE=$(git rev-parse HEAD)
    # gstack's setup rebuilds checked-in binaries; reset before pull to avoid --ff-only abort.
    if ! git diff --quiet || ! git diff --cached --quiet; then
        git reset --hard HEAD >/dev/null
    fi
    git pull --ff-only
    AFTER=$(git rev-parse HEAD)
    if [ "$BEFORE" != "$AFTER" ]; then
        echo "  Updated $(git log --oneline "$BEFORE..$AFTER" | wc -l | tr -d ' ') commits"
        echo "  Re-running gstack setup..."
        ./setup
    else
        echo "  Already up to date."
    fi
else
    echo "  ERROR: gstack not found. Run ./setup first."
    exit 1
fi

# --- 2. superpowers ---
echo ""
echo "[2/3] Updating superpowers skills..."
if [ -d "$UPSTREAM_DIR/superpowers/.git" ]; then
    cd "$UPSTREAM_DIR/superpowers"
    BEFORE=$(git rev-parse HEAD)
    git pull --ff-only
    AFTER=$(git rev-parse HEAD)
    if [ "$BEFORE" != "$AFTER" ]; then
        echo "  Updated $(git log --oneline "$BEFORE..$AFTER" | wc -l | tr -d ' ') commits"
    else
        echo "  Already up to date."
    fi
    for skill in $SUPERPOWERS_SKILLS; do
        if [ -d "$UPSTREAM_DIR/superpowers/skills/$skill" ]; then
            mkdir -p "$SKILLS_DIR/$skill"
            cp -r "$UPSTREAM_DIR/superpowers/skills/$skill/"* "$SKILLS_DIR/$skill/"
            echo "  Refreshed $skill"
        fi
    done
else
    echo "  ERROR: superpowers not found. Run ./setup first."
    exit 1
fi

# --- 3. custom skills ---
echo ""
echo "[3/3] Refreshing custom pipeline skills..."
for skill in $CUSTOM_SKILLS; do
    mkdir -p "$SKILLS_DIR/$skill"
    cp -r "$REPO_DIR/skills/$skill/"* "$SKILLS_DIR/$skill/"
    echo "  Refreshed $skill"
done

echo ""
echo "=== Update complete. ==="
